// Configuration
const CONFIG = {
    delayTime: 1000,
    logToConsole: true,
    maxScrollAttempts: 0,
    reactionHoverDelay: 150,
    retryAttempts: 5,
    noNewMessagesThreshold: 3,
    previewTheme: 'light'
};

let stopExport = false;

function getChatName() {
    const chatSelectors = [
        '[data-tid="chat-header-text"]',
        '[data-tid="chat-header-title"]',
        '.chat-header-title',
        '[data-tid="channel-header-title"]',
        '.channel-name-text',
        '[data-tid="meeting-chat-header"]',
        '[role="heading"][aria-level="2"]',
        '.title-wrapper',
        '.chat-name',
        '[data-tid="conversationHeader"]',
        '.ts-title-text'
    ];

    for (const selector of chatSelectors) {
        const element = document.querySelector(selector);
        if (element && element.textContent.trim()) {
            return cleanChatName(element.textContent.trim());
        }
    }

    const participantNames = Array.from(document.querySelectorAll('[data-tid="message-username"]'))
        .map(el => el.textContent.trim())
        .filter((v, i, a) => a.indexOf(v) === i);

    if (participantNames.length > 0) {
        if (participantNames.length === 2) {
            return `Chat with ${participantNames.join(' and ')}`;
        } else {
            return `Group Chat (${participantNames.length} participants)`;
        }
    }

    return 'Teams Chat';
}

function cleanChatName(name) {
    return name
        .replace(/[<>:"/\\|?*]/g, '')
        .replace(/\s+/g, ' ')
        .trim();
}

function parseTimeOnDate(timeText, referenceDate) {
    const parsedTime = Date.parse(`${referenceDate.toDateString()} ${timeText}`);
    return Number.isNaN(parsedTime) ? null : parsedTime;
}

function getTimestampSortValue(rawTimestamp) {
    if (!rawTimestamp) {
        return null;
    }

    const normalizedTimestamp = rawTimestamp
        .replace(/[\u200e\u200f]/g, '')
        .replace(/\s+/g, ' ')
        .trim();

    const directParse = Date.parse(normalizedTimestamp);
    if (!Number.isNaN(directParse)) {
        return directParse;
    }

    const now = new Date();
    const relativeMatch = normalizedTimestamp.match(/^(Today|Yesterday)\s*(?:at)?\s*(.+)$/i);
    if (relativeMatch) {
        const referenceDate = new Date(now);
        if (relativeMatch[1].toLowerCase() === 'yesterday') {
            referenceDate.setDate(referenceDate.getDate() - 1);
        }

        return parseTimeOnDate(relativeMatch[2], referenceDate);
    }

    const weekdayMatch = normalizedTimestamp.match(/^(Sunday|Monday|Tuesday|Wednesday|Thursday|Friday|Saturday)\s*(?:at)?\s*(.+)$/i);
    if (weekdayMatch) {
        const weekdayNames = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
        const targetDay = weekdayNames.indexOf(weekdayMatch[1].toLowerCase());
        if (targetDay !== -1) {
            const referenceDate = new Date(now);
            let dayOffset = (referenceDate.getDay() - targetDay + 7) % 7;
            if (dayOffset === 0 && Date.parse(weekdayMatch[2]) > now.getTime()) {
                dayOffset = 7;
            }
            referenceDate.setDate(referenceDate.getDate() - dayOffset);

            return parseTimeOnDate(weekdayMatch[2], referenceDate);
        }
    }

    const timeOnlyParse = parseTimeOnDate(normalizedTimestamp, now);
    return timeOnlyParse;
}

function getTimestampInfo(timestampElement) {
    const rawCandidates = [
        timestampElement.getAttribute('datetime'),
        timestampElement.getAttribute('dateTime'),
        timestampElement.getAttribute('title'),
        timestampElement.getAttribute('aria-label'),
        timestampElement.textContent
    ];

    const displayTimestamp = (timestampElement.textContent || '').trim();
    const rawTimestamp = rawCandidates.find(value => value && value.trim());

    return {
        displayTimestamp,
        sortTimestamp: getTimestampSortValue(rawTimestamp)
    };
}

function normalizeInlineText(text) {
    return text
        .replace(/\u00a0/g, ' ')
        .replace(/[\t\r\n]+/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
}

function normalizeMarkdown(markdown) {
    return markdown
        .replace(/\u00a0/g, ' ')
        .replace(/[ \t]+\n/g, '\n')
        .replace(/\n{3,}/g, '\n\n')
        .trim();
}

function extractInlineMarkdown(node) {
    if (!node) {
        return '';
    }

    if (node.nodeType === Node.TEXT_NODE) {
        return normalizeInlineText(node.textContent || '');
    }

    if (node.nodeType !== Node.ELEMENT_NODE) {
        return '';
    }

    const tagName = node.tagName.toLowerCase();
    const childContent = Array.from(node.childNodes)
        .map(child => extractInlineMarkdown(child))
        .join(' ')
        .replace(/\s+/g, ' ')
        .trim();

    if (!childContent && tagName !== 'br') {
        return '';
    }

    switch (tagName) {
        case 'strong':
        case 'b':
            return `**${childContent}**`;
        case 'em':
        case 'i':
            return `*${childContent}*`;
        case 'code':
            return `\`${childContent}\``;
        case 'a': {
            const href = node.getAttribute('href');
            return href ? `[${childContent || href}](${href})` : childContent;
        }
        case 'br':
            return '\n';
        default:
            return childContent;
    }
}

function extractTextAndNestedLists(node, indentLevel) {
    const textParts = [];
    const nestedLists = [];

    Array.from(node.childNodes).forEach(child => {
        if (child.nodeType === Node.ELEMENT_NODE) {
            const tagName = child.tagName.toLowerCase();
            if (tagName === 'ul' || tagName === 'ol') {
                nestedLists.push(extractListMarkdown(child, indentLevel));
                return;
            }

            if (tagName === 'div' || tagName === 'p') {
                const nestedContent = extractTextAndNestedLists(child, indentLevel);
                if (nestedContent.text) {
                    textParts.push(nestedContent.text);
                }
                nestedLists.push(...nestedContent.nestedLists);
                return;
            }
        }

        const inlineContent = extractInlineMarkdown(child);
        if (inlineContent) {
            textParts.push(inlineContent);
        }
    });

    return {
        text: normalizeInlineText(textParts.join(' ')),
        nestedLists
    };
}

function extractListItemMarkdown(listItem, indentLevel, marker) {
    const { text, nestedLists } = extractTextAndNestedLists(listItem, indentLevel + 1);
    const indentation = '  '.repeat(indentLevel);
    let markdown = `${indentation}${marker} ${text || '[No message content]'}`;

    if (nestedLists.length > 0) {
        markdown += `\n${nestedLists.join('\n')}`;
    }

    return markdown;
}

function extractListMarkdown(listElement, indentLevel = 0) {
    const isOrderedList = listElement.tagName.toLowerCase() === 'ol';
    const startIndex = isOrderedList ? parseInt(listElement.getAttribute('start'), 10) || 1 : 1;

    return Array.from(listElement.children)
        .filter(child => child.tagName && child.tagName.toLowerCase() === 'li')
        .map((listItem, index) => {
            const marker = isOrderedList ? `${startIndex + index}.` : '-';
            return extractListItemMarkdown(listItem, indentLevel, marker);
        })
        .join('\n');
}

function extractMarkdownFromElement(element) {
    if (!element) {
        return '';
    }

    const markdownBlocks = Array.from(element.childNodes)
        .map(node => {
            if (node.nodeType === Node.TEXT_NODE) {
                return normalizeInlineText(node.textContent || '');
            }

            if (node.nodeType !== Node.ELEMENT_NODE) {
                return '';
            }

            const tagName = node.tagName.toLowerCase();

            if (tagName === 'ul' || tagName === 'ol') {
                return extractListMarkdown(node);
            }

            if (tagName === 'div' || tagName === 'p') {
                const { text, nestedLists } = extractTextAndNestedLists(node, 1);
                const blockParts = [];
                if (text) {
                    blockParts.push(text);
                }
                if (nestedLists.length > 0) {
                    blockParts.push(nestedLists.join('\n'));
                }
                return blockParts.join('\n');
            }

            return extractInlineMarkdown(node);
        })
        .filter(Boolean)
        .join('\n\n');

    return normalizeMarkdown(markdownBlocks) || normalizeInlineText(element.textContent || '');
}

function deduplicateBy(items, getKey) {
    const seen = new Set();

    return items.filter(item => {
        const key = getKey(item);
        if (!key || seen.has(key)) {
            return false;
        }

        seen.add(key);
        return true;
    });
}

function extractReactionCount(reactionText) {
    const matches = (reactionText || '').match(/\b\d+\b/g);
    if (!matches || matches.length === 0) {
        return 1;
    }

    return parseInt(matches[matches.length - 1], 10) || 1;
}

function getReferencedElementText(sourceElement, attributeName) {
    const attributeValue = sourceElement.getAttribute(attributeName);
    if (!attributeValue) {
        return '';
    }

    return attributeValue
        .split(/\s+/)
        .map(id => {
            const referencedElement = document.getElementById(id);
            return referencedElement ? normalizeInlineText(referencedElement.textContent || '') : '';
        })
        .filter(Boolean)
        .join(' ');
}

function getReactionMetadataText(reactionElement) {
    return [
        reactionElement.getAttribute('aria-label'),
        reactionElement.getAttribute('aria-description'),
        reactionElement.getAttribute('title'),
        getReferencedElementText(reactionElement, 'aria-labelledby'),
        getReferencedElementText(reactionElement, 'aria-describedby'),
        reactionElement.textContent
    ]
        .map(value => normalizeInlineText(value || ''))
        .filter(Boolean)
        .join(' | ');
}

function extractReactionUsers(reactionText) {
    if (!reactionText) {
        return [];
    }

    const userMatches = [
        ...reactionText.matchAll(/(?:from|by)\s+([^.|;]+)/gi),
        ...reactionText.matchAll(/([^.|;]+?)\s+reacted\s+(?:with|using)?/gi)
    ];

    const users = userMatches
        .flatMap(match => match[1].split(/,|\band\b/gi))
        .map(user => user.replace(/\b\d+\s+others?\b/gi, '').trim())
        .map(user => user.replace(/^[:\-\s]+|[:\-\s]+$/g, ''))
        .filter(Boolean)
        .filter(user => !/^(like|heart|laugh|surprised|sad|angry|reaction|reactions)$/i.test(user));

    return [...new Set(users)];
}

function cleanReactionLabel(reactionText) {
    if (!reactionText) {
        return '';
    }

    return reactionText
        .replace(/[\u200e\u200f]/g, '')
        .replace(/\b\d+\b/g, '')
        .replace(/\b(reaction|reactions|reacted|people|person|users?|user|by|with|total|summary|from)\b/gi, '')
        .replace(/[^|]*\|/g, '')
        .replace(/[.,:;()]/g, ' ')
        .replace(/\s+/g, ' ')
        .replace(/[.\-:,;]+$/g, '')
        .trim();
}

function extractReactionVisual(reactionElement) {
    const emojiImage = reactionElement.querySelector('img[alt], img[aria-label]');
    if (emojiImage) {
        return normalizeInlineText(emojiImage.getAttribute('alt') || emojiImage.getAttribute('aria-label') || '');
    }

    const emojiMatch = (reactionElement.textContent || '').match(/[\p{Extended_Pictographic}\u2600-\u27BF]/u);
    if (emojiMatch) {
        return emojiMatch[0];
    }

    return '';
}

function sleep(milliseconds) {
    return new Promise(resolve => setTimeout(resolve, milliseconds));
}

function isElementVisible(element) {
    if (!element) {
        return false;
    }

    const rect = element.getBoundingClientRect();
    const style = window.getComputedStyle(element);

    return rect.width > 0 &&
        rect.height > 0 &&
        style.visibility !== 'hidden' &&
        style.display !== 'none';
}

function triggerReactionHover(reactionElement, eventNames) {
    const rect = reactionElement.getBoundingClientRect();
    const clientX = rect.left + (rect.width / 2);
    const clientY = rect.top + (rect.height / 2);

    eventNames.forEach(eventName => {
        reactionElement.dispatchEvent(new MouseEvent(eventName, {
            view: window,
            bubbles: true,
            cancelable: true,
            clientX,
            clientY
        }));

        reactionElement.dispatchEvent(new PointerEvent(eventName, {
            view: window,
            bubbles: true,
            cancelable: true,
            clientX,
            clientY,
            pointerId: 1,
            pointerType: 'mouse',
            isPrimary: true
        }));
    });
}

function triggerReactionActivation(reactionElement) {
    const rect = reactionElement.getBoundingClientRect();
    const clientX = rect.left + (rect.width / 2);
    const clientY = rect.top + (rect.height / 2);

    ['pointerdown', 'mousedown', 'pointerup', 'mouseup', 'click'].forEach(eventName => {
        const EventType = eventName.startsWith('pointer') ? PointerEvent : MouseEvent;
        reactionElement.dispatchEvent(new EventType(eventName, {
            view: window,
            bubbles: true,
            cancelable: true,
            clientX,
            clientY,
            pointerId: 1,
            pointerType: 'mouse',
            isPrimary: true
        }));
    });

    if (typeof reactionElement.click === 'function') {
        reactionElement.click();
    }
}

function dismissReactionPopover(reactionElement) {
    triggerReactionHover(reactionElement, ['pointerleave', 'mouseleave', 'mouseout']);
    document.dispatchEvent(new KeyboardEvent('keydown', {
        key: 'Escape',
        code: 'Escape',
        bubbles: true,
        cancelable: true
    }));

    if (typeof reactionElement.blur === 'function') {
        reactionElement.blur();
    }
}

function extractReactionUsersFromPopover(popoverElement) {
    if (!popoverElement) {
        return [];
    }

    const userItems = Array.from(popoverElement.querySelectorAll('[data-tid="diverse-reaction-user-list-item"]'));
    const users = userItems.map(item => {
        const namedElement = item.querySelector('.fui-MenuItem__content span[dir="auto"], .fui-MenuItem__content span');
        if (namedElement) {
            return normalizeInlineText(namedElement.textContent || '');
        }

        const ariaLabel = normalizeInlineText(item.getAttribute('aria-label') || '');
        const chatMatch = ariaLabel.match(/^Chat with\s+([^,]+)/i);
        return chatMatch ? chatMatch[1].trim() : ariaLabel;
    }).filter(Boolean);

    return [...new Set(users)];
}

async function getReactionUsersFromHover(reactionElement) {
    const existingPopovers = new Set(Array.from(document.querySelectorAll('[data-tid="diverse-reaction-user-list"]')));
    const toolbar = reactionElement.closest('[data-tid="diverse-reaction-summary"]');

    reactionElement.scrollIntoView({ block: 'nearest', inline: 'nearest' });

    if (typeof reactionElement.focus === 'function') {
        reactionElement.focus({ preventScroll: true });
    }

    if (toolbar) {
        triggerReactionHover(toolbar, ['pointerenter', 'mouseenter', 'mouseover', 'mousemove']);
    }

    triggerReactionHover(reactionElement, ['pointerenter', 'mouseenter', 'mouseover', 'mousemove']);

    for (let attempt = 0; attempt < 8; attempt++) {
        if (attempt === 2 || attempt === 5) {
            triggerReactionActivation(reactionElement);
        }

        await sleep(CONFIG.reactionHoverDelay);

        const popovers = Array.from(document.querySelectorAll('[data-tid="diverse-reaction-user-list"]'))
            .filter(popover => isElementVisible(popover.closest('[role="presentation"]') || popover));

        const matchingPopover = popovers.find(popover => !existingPopovers.has(popover)) || popovers[popovers.length - 1];
        const users = extractReactionUsersFromPopover(matchingPopover);
        if (users.length > 0) {
            dismissReactionPopover(reactionElement);
            await sleep(50);
            return users;
        }
    }

    dismissReactionPopover(reactionElement);
    await sleep(50);
    return [];
}

function isReactionPlaceholderElement(reactionElement) {
    if (!reactionElement) {
        return false;
    }

    return Boolean(
        reactionElement.closest('[data-tid="reactions-summary-item-renderer"]') ||
        reactionElement.closest('[data-tid="add-reaction-picker-entry-point-button"]') ||
        reactionElement.closest('.add-reaction-picker-entry-point-button') ||
        reactionElement.matches('[data-tid="diverse-reaction-summary"]') ||
        reactionElement.matches('[data-tid="reactions-summary-item-renderer"]') ||
        reactionElement.matches('[data-tid="add-reaction-picker-entry-point-button"]') ||
        reactionElement.matches('.add-reaction-picker-entry-point-button') ||
        reactionElement.getAttribute('aria-label') === 'Reaction summary' ||
        reactionElement.getAttribute('aria-label') === 'More reactions' ||
        reactionElement.getAttribute('title') === 'More reactions'
    );
}

async function getReactionInfo(reactionElement) {
    if (isReactionPlaceholderElement(reactionElement)) {
        return null;
    }

    const rawLabel = getReactionMetadataText(reactionElement);

    if (!rawLabel) {
        return null;
    }

    if (/add reaction|react to this message|open reactions?|more reactions?|show reactions?|reaction summary/i.test(rawLabel)) {
        return null;
    }

    const visual = extractReactionVisual(reactionElement);
    const label = cleanReactionLabel(rawLabel) || visual;
    if (!label && !visual) {
        return null;
    }

    const hoverUsers = await getReactionUsersFromHover(reactionElement);
    const users = [...new Set([...extractReactionUsers(rawLabel), ...hoverUsers])];

    return {
        label: label || visual,
        visual,
        count: extractReactionCount(rawLabel),
        users,
        rawLabel
    };
}

async function getMessageReactions(messageElement) {
    const reactionSelectors = [
        'button[data-tid="diverse-reaction-pill-button"]',
        '[data-tid="diverse-reaction-pill-button"]',
        '[data-tid*="reaction"]',
        '[class*="reaction"]',
        '[id*="reaction"]',
        'button[aria-label*="reaction"]',
        '[aria-label*="reacted"]',
        '[title*="reaction"]'
    ];

    const reactionElements = deduplicateBy(
        reactionSelectors.flatMap(selector => Array.from(messageElement.querySelectorAll(selector))),
        element => element
    );

    const reactions = [];
    for (const reactionElement of reactionElements) {
        const reaction = await getReactionInfo(reactionElement);
        if (reaction) {
            reactions.push(reaction);
        }
    }

    return deduplicateBy(
        reactions,
        reaction => `${reaction.label}|${reaction.count}|${reaction.users.join(',')}`
    );
}

function formatReactionSummary(reaction) {
    const prefix = reaction.visual && reaction.visual !== reaction.label
        ? `${reaction.visual} `
        : '';

    const userSummary = reaction.users && reaction.users.length > 0
        ? ` by ${reaction.users.join(', ')}`
        : '';

    return `${prefix}${reaction.label}${reaction.count > 1 ? ` x${reaction.count}` : ''}${userSummary}`.trim();
}

function createReactionMarkdown(reactions) {
    if (!reactions || reactions.length === 0) {
        return '';
    }

    return `**Reactions:** ${reactions.map(formatReactionSummary).join(', ')}`;
}

function escapeHtml(text) {
    return (text || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function renderInlineMarkdown(markdown) {
    let html = escapeHtml(markdown || '');
    const codeSpans = [];

    html = html.replace(/`([^`]+)`/g, (_, code) => {
        const placeholder = `__CODE_SPAN_${codeSpans.length}__`;
        codeSpans.push(`<code>${escapeHtml(code)}</code>`);
        return placeholder;
    });

    html = html
        .replace(/!\[(.*?)\]\((.*?)\)/g, (_, alt, src) => `<img alt="${escapeHtml(alt)}" src="${escapeHtml(src)}">`)
        .replace(/\[(.*?)\]\((.*?)\)/g, (_, text, href) => `<a href="${escapeHtml(href)}" target="_blank" rel="noopener noreferrer">${text}</a>`)
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>');

    codeSpans.forEach((codeSpan, index) => {
        html = html.replace(`__CODE_SPAN_${index}__`, codeSpan);
    });

    return html;
}

function getListItemInfo(line) {
    const match = line.match(/^(\s*)([-*]|\d+\.)\s+(.*)$/);
    if (!match) {
        return null;
    }

    return {
        indent: match[1].length,
        type: /\d+\./.test(match[2]) ? 'ol' : 'ul',
        content: match[3]
    };
}

function renderMarkdownList(lines, startIndex, baseIndent) {
    const firstItem = getListItemInfo(lines[startIndex]);
    if (!firstItem) {
        return { html: '', nextIndex: startIndex + 1 };
    }

    const listType = firstItem.type;
    let html = `<${listType}>`;
    let index = startIndex;

    while (index < lines.length) {
        const item = getListItemInfo(lines[index]);
        if (!item || item.indent < baseIndent || item.type !== listType) {
            break;
        }

        if (item.indent > baseIndent) {
            break;
        }

        html += `<li>${renderInlineMarkdown(item.content)}`;
        index += 1;

        while (index < lines.length) {
            const nextItem = getListItemInfo(lines[index]);
            if (nextItem) {
                if (nextItem.indent > baseIndent) {
                    const nestedList = renderMarkdownList(lines, index, nextItem.indent);
                    html += nestedList.html;
                    index = nestedList.nextIndex;
                    continue;
                }

                if (nextItem.indent === baseIndent) {
                    break;
                }

                if (nextItem.indent < baseIndent) {
                    break;
                }
            }

            if (!lines[index].trim()) {
                index += 1;
                continue;
            }

            html += `<br>${renderInlineMarkdown(lines[index].trim())}`;
            index += 1;
        }

        html += '</li>';
    }

    html += `</${listType}>`;
    return { html, nextIndex: index };
}

function renderMarkdownToHtml(markdown) {
    const lines = (markdown || '').split('\n');
    const htmlParts = [];
    let index = 0;

    while (index < lines.length) {
        const line = lines[index];
        const trimmedLine = line.trim();

        if (!trimmedLine) {
            index += 1;
            continue;
        }

        if (trimmedLine === '---') {
            htmlParts.push('<hr>');
            index += 1;
            continue;
        }

        if (trimmedLine.startsWith('```')) {
            const codeLines = [];
            index += 1;
            while (index < lines.length && !lines[index].trim().startsWith('```')) {
                codeLines.push(lines[index]);
                index += 1;
            }
            if (index < lines.length) {
                index += 1;
            }
            htmlParts.push(`<pre><code>${escapeHtml(codeLines.join('\n'))}</code></pre>`);
            continue;
        }

        const headingMatch = trimmedLine.match(/^###\s+(.*)$/);
        if (headingMatch) {
            htmlParts.push(`<h3>${renderInlineMarkdown(headingMatch[1])}</h3>`);
            index += 1;
            continue;
        }

        const listItem = getListItemInfo(line);
        if (listItem) {
            const listHtml = renderMarkdownList(lines, index, listItem.indent);
            htmlParts.push(listHtml.html);
            index = listHtml.nextIndex;
            continue;
        }

        const paragraphLines = [trimmedLine];
        index += 1;

        while (index < lines.length) {
            const nextLine = lines[index];
            const nextTrimmedLine = nextLine.trim();
            if (!nextTrimmedLine || nextTrimmedLine === '---' || nextTrimmedLine.startsWith('```') || nextTrimmedLine.startsWith('### ') || getListItemInfo(nextLine)) {
                break;
            }
            paragraphLines.push(nextTrimmedLine);
            index += 1;
        }

        htmlParts.push(`<p>${paragraphLines.map(renderInlineMarkdown).join('<br>')}</p>`);
    }

    return htmlParts.join('');
}

function getPreviewTrustedTypesPolicy(targetWindow) {
    if (!targetWindow || !targetWindow.trustedTypes || typeof targetWindow.trustedTypes.createPolicy !== 'function') {
        return null;
    }

    if (targetWindow.__teamsMarkdownExporterTrustedTypesPolicy) {
        return targetWindow.__teamsMarkdownExporterTrustedTypesPolicy;
    }

    try {
        targetWindow.__teamsMarkdownExporterTrustedTypesPolicy = targetWindow.trustedTypes.createPolicy(
            'teams-markdown-exporter-preview',
            {
                createHTML: html => html
            }
        );
    } catch (error) {
        targetWindow.__teamsMarkdownExporterTrustedTypesPolicy = null;
    }

    return targetWindow.__teamsMarkdownExporterTrustedTypesPolicy;
}

function setPreviewHtml(previewElement, html, targetWindow) {
    const trustedTypesPolicy = getPreviewTrustedTypesPolicy(targetWindow);

    if (trustedTypesPolicy) {
        previewElement.innerHTML = trustedTypesPolicy.createHTML(html);
        return;
    }

    previewElement.textContent = html.replace(/<[^>]+>/g, '');
}

function convertToMarkdown(messages, chatName) {
    let markdown = `# ${chatName}\n\n`;
    markdown += `*Teams Chat Export - ${new Date().toLocaleString()}*\n\n---\n\n`;

    messages.forEach(msg => {
        markdown += `### ${msg.sender} (${msg.timestamp})\n\n`;
        let content = msg.content.replace(/`([^`]+)`/g, '```\n$1\n```');
        markdown += `${content}\n\n`;

        const reactionMarkdown = createReactionMarkdown(msg.reactions);
        if (reactionMarkdown) {
            markdown += `${reactionMarkdown}\n\n`;
        }

        if (msg.images && msg.images.length > 0) {
            msg.images.forEach(image => {
                markdown += `![${image.alt}](${image.src})\n\n`;
            });
        }

        markdown += '---\n\n';
    });

    return markdown;
}

function downloadMarkdown(markdown, filename) {
    const blob = new Blob([markdown], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
}

const getSender = (messageElement) => {
    const senderElement = messageElement.querySelector('[data-tid="message-author-name"]');
    return senderElement ? senderElement.textContent.trim() : 'Unknown';
};

